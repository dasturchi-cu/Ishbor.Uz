{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "IshBor: Dev Full Stack",
      "type": "shell",
      "command": "pnpm dev:start",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "ishbor-dev",
        "pattern": { "regexp": "^.*$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Ready in|started server|Application startup complete|Uvicorn running"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "ishbor-dev"
      }
    },
    {
      "label": "IshBor: Dev Stop",
      "type": "shell",
      "command": "pnpm dev:stop",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "ishbor-dev"
      }
    },
    {
      "label": "IshBor: Dev (manual)",
      "type": "shell",
      "command": "pnpm dev:all",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
