# Supabase (Dashboard -> Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# MAJBURIY: legacy JWT anon key (eyJ...). Dashboard -> API -> anon public.
# sb_publishable_* faqat yangi SDK uchun; backend RLS va storage uchun JWT anon kerak.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-jwt-key
# Ixtiyoriy (frontend fallback). SUPABASE_ANON_KEY o'rniga buni qo'ymang.
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# FastAPI backend
NEXT_PUBLIC_API_URL=http://127.0.0.1:8002

# Cloudflare Turnstile (bo'sh = o'chirilgan)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Session idle timeout (daqiqa)
NEXT_PUBLIC_SESSION_IDLE_MINUTES=120

# Google OAuth — Supabase da Google provider yoqilgandan keyin true
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false

# Google Analytics 4 (ixtiyoriy)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Production canonical URL
NEXT_PUBLIC_SITE_URL=https://ishbor.uz

# Live Click/Payme (false = sandbox test mode on checkout)
NEXT_PUBLIC_PAYMENTS_ENABLED=false

# WebRTC video calls — optional TURN for production NAT (comma-separated STUN URLs)
# NEXT_PUBLIC_WEBRTC_STUN_URLS=stun:stun.l.google.com:19302
# NEXT_PUBLIC_WEBRTC_TURN_URL=turn:turn.example.com:3478
# NEXT_PUBLIC_WEBRTC_TURN_USERNAME=
# NEXT_PUBLIC_WEBRTC_TURN_CREDENTIAL=

# Request debug (dev): console da har bir API chaqiruvini sanash
# NEXT_PUBLIC_REQUEST_DEBUG=1

# Supabase DB/auth/realtime audit (dev): top-10 manba + oxirgi 1 soat count
# NEXT_PUBLIC_SUPABASE_REQUEST_DEBUG=1
# backend/.env: SUPABASE_REQUEST_DEBUG=1

# Dev da har restartda db push o'tkazmaslik (migration list sync bo'lsa yetarli)
# SUPABASE_SKIP_DB_PUSH=1

# Edge middleware profile cache (production: random 32+ byte secret — REQUIRED in prod)
# openssl rand -hex 32
MIDDLEWARE_CACHE_SECRET=

NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
