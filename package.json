{
  "name": "ishbor-uz",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:api": "cd backend && .venv\\Scripts\\python -m uvicorn app.main:app --reload --reload-dir app --host 127.0.0.1 --port 8002",
    "dev:all": "concurrently -n frontend,backend -c cyan,magenta --handle-input=false \"pnpm dev\" \"pnpm dev:api\"",
    "dev:start": "powershell -ExecutionPolicy Bypass -File scripts/dev.ps1",
    "dev:check": "powershell -ExecutionPolicy Bypass -File scripts/dev-check.ps1",
    "dev:check:strict": "powershell -ExecutionPolicy Bypass -File scripts/dev-check.ps1 -Strict",
    "db:push": "supabase db push --linked --yes",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "verify": "pnpm type-check && pnpm lint && pnpm test && pnpm test:backend && pnpm build",
    "preflight": "powershell -ExecutionPolicy Bypass -File scripts/preflight.ps1",
    "setup:production": "powershell -ExecutionPolicy Bypass -File scripts/setup-production.ps1",
    "health": "powershell -ExecutionPolicy Bypass -File scripts/health-check.ps1",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:backend": "cd backend && .venv\\Scripts\\python -m pytest",
    "test:all": "pnpm test:backend && pnpm test",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@sentry/nextjs": "^10.57.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.1",
    "@tanstack/react-query": "^5.101.0",
    "@vercel/analytics": "2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "next": "16.2.7",
    "react": "^19",
    "react-dom": "^19",
    "recharts": "^3.8.1",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.52.0",
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "postcss": "^8.5",
    "tailwindcss": "^4.2.0",
    "typescript": "5.7.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^3.2.6"
  }
}