# Supabase (Project Settings → API)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# CORS
CORS_ORIGINS=http://localhost:3000

# Payment webhooks (Click/Payme live rejimida majburiy)
PAYMENT_WEBHOOK_SECRET=generate-a-long-random-secret

# Click SHOP-API (merchant panel → API sozlamalari)
CLICK_MERCHANT_ID=0
CLICK_SERVICE_ID=0
CLICK_SECRET_KEY=your-click-secret-key
# To'lovdan keyin qaytish URL (bo'sh bo'lsa CORS_ORIGINS dan olinadi)
CLICK_RETURN_URL=http://localhost:3000/dashboard/orders

# Payme Merchant API (kassa sozlamalari)
PAYME_MERCHANT_ID=your-cashbox-id
PAYME_SECRET_KEY=your-payme-secret-key
PAYME_LOGIN=Paycom
# Payme kassada belgilangan account maydon nomi (odatda order_id)
# Payme kassada account maydoni — intent id (tavsiya)
PAYME_ACCOUNT_FIELD=payment_intent_id
PAYME_RETURN_URL=http://localhost:3000/dashboard/orders

# Sentry (ixtiyoriy — bo'sh bo'lsa o'chirilgan)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# Production
ENVIRONMENT=development
DOCS_ENABLED=true
# Container port (Docker/Railway/Render)
PORT=8000

# Email (ixtiyoriy — Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=IshBor.uz <hello@ishbor.uz>
